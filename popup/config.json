        { "keys": ["Alt", "Home"], "description": "Go to top" }
      ]
    },
    {
      "group": "Compact View",
      "module": "compactView",
      "items": [
        { "keys": ["Alt", "E"], "description": "Expand/collapse message" }
      ]
    },
    {
      "group": "Bookmarks",
      "module": "bookmarks",
      "items": [
        { "keys": ["Alt", "B"], "description": "Toggle bookmark" },
        { "keys": ["Alt", "Shift", "B"], "description": "Open bookmarks panel" }
      ]
    }
  ],

  "emojiCategories": {
