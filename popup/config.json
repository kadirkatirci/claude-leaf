  },

  "settingsSchema": {
    "navigation": {
      "title": "Navigation",
      "fields": [
        { "id": "nav-position", "key": "position", "type": "select", "label": "Position", "options": [{"value": "right", "label": "Right"}, {"value": "left", "label": "Left"}] },
        { "id": "nav-counter", "key": "showCounter", "type": "toggle", "label": "Show message counter" },
        { "id": "nav-smooth", "key": "smoothScroll", "type": "toggle", "label": "Smooth scroll" },
        { "id": "nav-keyboard", "key": "keyboardShortcuts", "type": "toggle", "label": "Keyboard shortcuts" },
        { "id": "nav-highlight", "key": "highlightDuration", "type": "number", "label": "Highlight duration (ms)", "min": 0, "max": 5000, "step": 100 },
        { "id": "nav-opacity", "key": "general.opacity", "type": "range", "label": "Opacity", "min": 0.3, "max": 1, "step": 0.1, "displayId": "nav-opacity-value", "global": true }
      ]
    },
    "editHistory": {
      "title": "Edit History",
      "fields": [
        { "id": "edit-badges", "key": "showBadges", "type": "toggle", "label": "Show edit badges" },
        { "id": "edit-highlight", "key": "highlightEdited", "type": "toggle", "label": "Highlight edited messages" }
      ]
    },
    "compactView": {
      "title": "Compact View",
      "fields": [
        { "id": "compact-autoCollapse", "key": "autoCollapse", "type": "toggle", "label": "Auto-collapse" },
        { "id": "compact-keyboard", "key": "keyboardShortcuts", "type": "toggle", "label": "Keyboard shortcuts" },
        { "id": "compact-minLines", "key": "minLines", "type": "number", "label": "Min lines to collapse", "min": 5, "max": 100, "step": 1 },
        { "id": "compact-previewLines", "key": "previewLines", "type": "number", "label": "Preview lines shown", "min": 1, "max": 20, "step": 1 }
      ]
    },
    "bookmarks": {
      "title": "Bookmarks",
      "fields": [
        { "id": "bookmarks-keyboard", "key": "keyboardShortcuts", "type": "toggle", "label": "Keyboard shortcuts" },
        { "id": "bookmarks-showOnHover", "key": "showOnHover", "type": "toggle", "label": "Show buttons on hover" }
      ]
    },
    "emojiMarkers": {
      "title": "Emoji Markers",
      "fields": [
        { "id": "emojiMarkers-showBadges", "key": "showBadges", "type": "toggle", "label": "Show badges" },
        { "id": "emojiMarkers-showOnHover", "key": "showOnHover", "type": "toggle", "label": "Show buttons on hover" },
        { "id": "emojiMarkers-favorites", "key": "favoriteEmojis", "type": "emoji-list", "label": "Favorite Emojis" }
      ]
    },
    "sidebarCollapse": {
      "title": "Sidebar Collapse",
      "fields": [
        { "id": "sidebarCollapse-rememberState", "key": "rememberState", "type": "toggle", "label": "Remember state" }
      ]
    },
    "contentFolding": {
      "title": "Content Folding",
      "subgroups": [
        {
          "title": "Headings",
          "fields": [
            { "id": "contentFolding-headings-enabled", "key": "headings.enabled", "type": "toggle", "label": "Enable" }
          ]
        },
        {
          "title": "Code Blocks",
          "fields": [
            { "id": "contentFolding-codeBlocks-enabled", "key": "codeBlocks.enabled", "type": "toggle", "label": "Enable" },
            { "id": "contentFolding-minLines", "key": "codeBlocks.minLines", "type": "number", "label": "Min lines", "min": 5, "max": 50, "step": 1 },
            { "id": "contentFolding-previewLines", "key": "codeBlocks.previewLines", "type": "number", "label": "Preview lines", "min": 1, "max": 10, "step": 1 },
            { "id": "contentFolding-autoCollapse", "key": "codeBlocks.autoCollapse", "type": "toggle", "label": "Auto-collapse" }
          ]
        },
        {
          "title": "Messages",
          "fields": [
            { "id": "contentFolding-messages-enabled", "key": "messages.enabled", "type": "toggle", "label": "Enable" },
            { "id": "contentFolding-messages-previewLines", "key": "messages.previewLines", "type": "number", "label": "Preview lines", "min": 1, "max": 10, "step": 1 }
          ]
        },
        {
          "title": "General",
          "fields": [
            { "id": "contentFolding-rememberState", "key": "rememberState", "type": "toggle", "label": "Remember fold states" }
          ]
        }
      ]
    }
  },

  "dataOptions": {
    "export": [
      { "id": "export-editHistory", "key": "editHistory", "storageKey": "editHistory", "dataPath": "history", "label": "Edit History" },
      { "id": "export-bookmarks", "key": "bookmarks", "storageKey": "bookmarks", "dataPath": "bookmarks", "label": "Bookmarks" },
      { "id": "export-emojiMarkers", "key": "emojiMarkers", "storageKey": "markers", "dataPath": "markers", "label": "Emoji Markers" },
      { "id": "export-settings", "key": "settings", "label": "Settings" }
    ],
    "clear": [
      { "id": "clear-editHistory", "storageKey": "editHistory", "label": "Edit History" },
      { "id": "clear-bookmarks", "storageKey": "bookmarks", "label": "Bookmarks" },
      { "id": "clear-emojiMarkers", "storageKey": "markers", "label": "Emoji Markers" }
    ]
  },

