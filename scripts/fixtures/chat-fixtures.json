      "features": ["navigation", "bookmarks", "emojiMarkers", "editHistory", "visual"],
      "visual": true,
      "notes": "Real medium chat capture with edit history, badges and modal coverage.",
      "smoke": {
        "minMessages": 20,
        "minUserMessages": 10,
        "requiresEditedMessages": true,
        "minEditedMessages": 1
      }
    },
    "long": {
      "captureId": "chat-live-long",
      "fixtureId": "chat-real-long",
      "route": "/chat/fixture-real-long",
      "pageType": "conversation",
      "features": ["navigation", "bookmarks", "emojiMarkers", "editHistory", "popup-sync", "visual"],
      "visual": true,
      "notes": "Real long chat capture for dense scrolling, panel lists and high-count counters.",
      "smoke": {
        "minMessages": 60,
