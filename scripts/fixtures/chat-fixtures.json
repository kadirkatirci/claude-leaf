{
  "order": ["short", "medium", "long"],
  "targets": {
    "short": {
      "captureId": "chat-live-short",
      "fixtureId": "chat-real-short",
      "route": "/chat/fixture-real-short",
      "pageType": "conversation",
      "features": ["navigation", "bookmarks", "emojiMarkers", "popup-sync", "keyboard"],
      "visual": true,
      "notes": "Real short chat capture with no edit history, used as the baseline conversation fixture.",
      "smoke": {
        "minMessages": 8,
        "minUserMessages": 4,
        "requiresEditedMessages": false
      }
    },
    "medium": {
      "captureId": "chat-live-medium",
      "fixtureId": "chat-real-medium",
      "route": "/chat/fixture-real-medium",
